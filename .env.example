PORT=5000
NODE_ENV=development
# Frontend URL(s) - supports comma-separated values for multiple origins
# Dev: http://localhost:5173 (also auto-includes 5174, 5175, 3000, and 127.0.0.1 variants)
# Prod: mirrormind-production.up.railway.app (without protocol - HTTPS is automatic)
# To support multiple origins: http://localhost:5173, https://mirrormind-production.up.railway.app
FRONTEND_URL=http://localhost:5173
# For production, set NODE_ENV=production and update FRONTEND_URL to: https://mirrormind-production.up.railway.app

# Set to 1 only when frontend/backend are on different sites and HTTPS is enabled.
# This switches auth cookie to SameSite=None; Secure.
# Uncomment for cross-site deployments in production:
# CROSS_SITE_COOKIES=1

#GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
#GOOGLE_CLIENT_SECRET=your-google-client-secret
# GitHub OAuth (for "publish to GitHub" without manual token paste)
# Create OAuth App in GitHub settings.
# Callback URL (dev): http://localhost:5000/api/oauth/callback?service=github
# GITHUB_CLIENT_ID=Iv1.xxxxx
# GITHUB_CLIENT_SECRET=xxxxx
# Optional env-specific creds:
# GITHUB_CLIENT_ID_DEV=Iv1.xxxxx
# GITHUB_CLIENT_SECRET_DEV=xxxxx
# GITHUB_CLIENT_ID_PROD=Ov23xxxx
# GITHUB_CLIENT_SECRET_PROD=xxxxx
# Optional override:
# GITHUB_OAUTH_CALLBACK_URL=http://localhost:5000/api/oauth/callback?service=github
# Optional scopes (default: repo read:user user:email)
# GITHUB_OAUTH_SCOPES=repo read:user user:email
# Optional backend fallback key. If omitted, frontend should send aiStudioApiKey in POST /api/agent/sessions/:sessionId/poc.
GOOGLE_API_KEY=your-gemini-api-key
# Optional: Live API model (default: gemini-2.5-flash-native-audio-preview-12-2025)
# GEMINI_LIVE_MODEL=gemini-live-2.5-flash-preview

JWT_SECRET=your-jwt-secret-min-32-chars
SESSION_SECRET=your-session-secret

# Optional: allow agent sessions without login (dev only)
# ALLOW_ANONYMOUS_AGENT=1

# Firebase (Firestore) - use firebase-key.json or env below
# GOOGLE_APPLICATION_CREDENTIALS=./firebase-key.json
# Preferred single var (JSON or base64 JSON):
# FIREBASE_SERVICE_ACCOUNT_KEY={...}
# Or a full service account JSON:
# FIREBASE_SERVICE_ACCOUNT_JSON={"project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n","client_email":"..."}
# Or base64 encoded service account JSON:
# FIREBASE_SERVICE_ACCOUNT_JSON_B64=eyJ0eXBlIjoic2VydmljZV9hY2NvdW50Iiwi...
# Or:
# FIREBASE_PROJECT_ID=
# FIREBASE_PRIVATE_KEY=
# FIREBASE_PRIVATE_KEY_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_CLIENT_ID=

# Notion (ideas + concept map sync)
# NOTION_API_KEY=secret_xxx
# NOTION_DATABASE_ID=your-database-id
# NOTION_TITLE_PROPERTY=Name

# POC ready notifications (optional)
# Webhook receiver for ready events
# POC_READY_WEBHOOK_URL=https://your-app.com/hooks/poc-ready
# Default AI Studio link used when request does not provide aiStudioLink
# AI_STUDIO_DEFAULT_LINK=https://aistudio.google.com/
# Email via Resend
# RESEND_API_KEY=re_xxx
# POC_READY_EMAIL_FROM=Mirror Mind <noreply@yourdomain.com>

# Optional GitHub fallback token for publishing POC repos.
# Prefer passing githubToken from frontend per user.
# GITHUB_TOKEN=ghp_xxx
