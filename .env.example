PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
# Set to 1 only when frontend/backend are on different sites and HTTPS is enabled.
# This switches auth cookie to SameSite=None; Secure.
# CROSS_SITE_COOKIES=1

GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_API_KEY=your-gemini-api-key
# Optional: Live API model (default: gemini-2.5-flash-native-audio-preview-12-2025)
# GEMINI_LIVE_MODEL=gemini-live-2.5-flash-preview

JWT_SECRET=your-jwt-secret-min-32-chars
SESSION_SECRET=your-session-secret

# Optional: allow agent sessions without login (dev only)
# ALLOW_ANONYMOUS_AGENT=1

# Firebase (Firestore) - use firebase-key.json or env below
# GOOGLE_APPLICATION_CREDENTIALS=./firebase-key.json
# Preferred single var (JSON or base64 JSON):
# FIREBASE_SERVICE_ACCOUNT_KEY={...}
# Or a full service account JSON:
# FIREBASE_SERVICE_ACCOUNT_JSON={"project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n","client_email":"..."}
# Or base64 encoded service account JSON:
# FIREBASE_SERVICE_ACCOUNT_JSON_B64=eyJ0eXBlIjoic2VydmljZV9hY2NvdW50Iiwi...
# Or:
# FIREBASE_PROJECT_ID=
# FIREBASE_PRIVATE_KEY=
# FIREBASE_PRIVATE_KEY_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_CLIENT_ID=

# Notion (ideas + concept map sync)
# NOTION_API_KEY=secret_xxx
# NOTION_DATABASE_ID=your-database-id
# NOTION_TITLE_PROPERTY=Name